# macOS
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp

# Claude Code local-only settings (but allow .claude/rules/ to be tracked)
.claude/settings.local.json
.claude/cache/

# Build artifacts
docs.zip

# Generated API reference (deno doc --html, regenerated by CI)
docs/api/

# Override global gitignore_global which ignores deno.lock —
# JSR/deno.land/x libraries should commit their lockfile for reproducibility.
!deno.lock

# Override global gitignore_global pattern `*secret*` so we can commit
# files with "secret" in their name (e.g. CI workflows).
!.github/workflows/*secret*
